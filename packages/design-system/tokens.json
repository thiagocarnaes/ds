{
  "$metadata": {
    "tokenSetOrder": ["global", "semantic", "dark"]
  },
  "global": {
    "color": {
      "navy": {
        "900": { "$value": "#060D18", "$type": "color", "$description": "Deepest background" },
        "800": { "$value": "#0D1B2E", "$type": "color", "$description": "Card surface" },
        "700": { "$value": "#122236", "$type": "color", "$description": "Secondary surface" },
        "600": { "$value": "#1E3A5A", "$type": "color", "$description": "Input / switch background" }
      },
      "cyan": {
        "500": { "$value": "#00D4FF", "$type": "color", "$description": "Primary brand" },
        "400": { "$value": "#33DDFF", "$type": "color", "$description": "Primary hover" },
        "200": { "$value": "#79E2F2", "$type": "color", "$description": "Light tint" }
      },
      "blue": {
        "600": { "$value": "#2979FF", "$type": "color", "$description": "Accent / secondary action" },
        "500": { "$value": "#4C9AFF", "$type": "color", "$description": "Focus ring" }
      },
      "teal": {
        "400": { "$value": "#00E5B0", "$type": "color", "$description": "Success / form focus" }
      },
      "red": {
        "500": { "$value": "#FF3D57", "$type": "color", "$description": "Destructive / error" }
      },
      "amber": {
        "500": { "$value": "#FF8B00", "$type": "color", "$description": "Warning / moved" }
      },
      "purple": {
        "400": { "$value": "#A78BFA", "$type": "color", "$description": "Discovery / new" }
      },
      "slate": {
        "500": { "$value": "#4D6A87", "$type": "color", "$description": "Muted foreground" },
        "400": { "$value": "#7BA3C8", "$type": "color", "$description": "Secondary text" },
        "200": { "$value": "#B8D0E8", "$type": "color", "$description": "Dimmed text" }
      },
      "white": { "$value": "#E8EDF5", "$type": "color", "$description": "Foreground on dark" }
    },
    "radius": {
      "sm":  { "$value": "4px",   "$type": "borderRadius" },
      "md":  { "$value": "8px",   "$type": "borderRadius" },
      "lg":  { "$value": "12px",  "$type": "borderRadius" },
      "xl":  { "$value": "16px",  "$type": "borderRadius" },
      "full":{ "$value": "9999px","$type": "borderRadius" }
    },
    "spacing": {
      "0.5": { "$value": "2px",  "$type": "spacing" },
      "1":   { "$value": "4px",  "$type": "spacing" },
      "2":   { "$value": "8px",  "$type": "spacing" },
      "3":   { "$value": "12px", "$type": "spacing" },
      "4":   { "$value": "16px", "$type": "spacing" },
      "6":   { "$value": "24px", "$type": "spacing" },
      "8":   { "$value": "32px", "$type": "spacing" },
      "12":  { "$value": "48px", "$type": "spacing" }
    },
    "fontSize": {
      "xs":   { "$value": "10px", "$type": "fontSize" },
      "sm":   { "$value": "12px", "$type": "fontSize" },
      "base": { "$value": "13px", "$type": "fontSize" },
      "md":   { "$value": "14px", "$type": "fontSize" },
      "lg":   { "$value": "16px", "$type": "fontSize" },
      "xl":   { "$value": "20px", "$type": "fontSize" },
      "2xl":  { "$value": "24px", "$type": "fontSize" },
      "display": { "$value": "32px", "$type": "fontSize" }
    }
  },
  "semantic": {
    "background":          { "$value": "{global.color.navy.900}",  "$type": "color" },
    "foreground":          { "$value": "{global.color.white}",     "$type": "color" },
    "card":                { "$value": "{global.color.navy.800}",  "$type": "color" },
    "card-foreground":     { "$value": "{global.color.white}",     "$type": "color" },
    "popover":             { "$value": "{global.color.navy.800}",  "$type": "color" },
    "popover-foreground":  { "$value": "{global.color.white}",     "$type": "color" },
    "primary":             { "$value": "{global.color.cyan.500}",  "$type": "color" },
    "primary-foreground":  { "$value": "{global.color.navy.900}",  "$type": "color" },
    "secondary":           { "$value": "{global.color.navy.700}",  "$type": "color" },
    "secondary-foreground":{ "$value": "{global.color.slate.400}", "$type": "color" },
    "muted":               { "$value": "{global.color.navy.800}",  "$type": "color" },
    "muted-foreground":    { "$value": "{global.color.slate.500}", "$type": "color" },
    "accent":              { "$value": "{global.color.blue.600}",  "$type": "color" },
    "accent-foreground":   { "$value": "{global.color.white}",     "$type": "color" },
    "destructive":         { "$value": "{global.color.red.500}",   "$type": "color" },
    "destructive-foreground":{ "$value": "{global.color.white}",   "$type": "color" },
    "border":              { "$value": "rgba(0, 212, 255, 0.10)",  "$type": "color" },
    "input":               { "$value": "{global.color.navy.700}",  "$type": "color" },
    "input-background":    { "$value": "{global.color.navy.700}",  "$type": "color" },
    "switch-background":   { "$value": "{global.color.navy.600}",  "$type": "color" },
    "ring":                { "$value": "{global.color.cyan.500}",  "$type": "color" },
    "radius":              { "$value": "{global.radius.md}",       "$type": "borderRadius" },
    "sidebar":             { "$value": "{global.color.navy.900}",  "$type": "color" },
    "sidebar-foreground":  { "$value": "{global.color.slate.400}", "$type": "color" },
    "sidebar-primary":     { "$value": "{global.color.cyan.500}",  "$type": "color" },
    "sidebar-primary-foreground": { "$value": "{global.color.navy.900}", "$type": "color" },
    "sidebar-accent":      { "$value": "{global.color.navy.800}",  "$type": "color" },
    "sidebar-accent-foreground":  { "$value": "{global.color.white}", "$type": "color" },
    "sidebar-border":      { "$value": "rgba(0, 212, 255, 0.08)",  "$type": "color" },
    "sidebar-ring":        { "$value": "{global.color.cyan.500}",  "$type": "color" }
  }
}
