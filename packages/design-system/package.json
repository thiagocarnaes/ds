{
  "name": "@design-system/components",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/design-system.js",
  "module": "./dist/design-system.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/design-system.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/design-system.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config vite.playground.config.ts",
    "build": "vue-tsc -p tsconfig.build.json --noEmit && vite build && vite build --config vite.playground.config.ts",
    "build:lib": "vue-tsc -p tsconfig.build.json --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@vueuse/core": "^13.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^17.4.4",
    "lucide-vue-next": "^1.0.0",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.1.2",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.8"
  }
}
